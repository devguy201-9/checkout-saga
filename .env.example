# ---------- App ----------
APP_ENV=development
LOG_LEVEL=debug

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=checkout
POSTGRES_PASSWORD=checkout_dev_pwd
POSTGRES_SSL_MODE=disable
POSTGRES_POOL_MAX=25

ORDER_DB_NAME=order_db
INVENTORY_DB_NAME=inventory_db
PAYMENT_DB_NAME=payment_db
SAGA_DB_NAME=saga_db

# ---------- Redis ----------
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- HTTP Ports ----------
ORDER_HTTP_PORT=8081
INVENTORY_HTTP_PORT=8082
PAYMENT_HTTP_PORT=8083
SAGA_HTTP_PORT=8084
NOTIFICATION_HTTP_PORT=8085

# ---------- gRPC Ports (planned) ----------
ORDER_GRPC_PORT=9081
INVENTORY_GRPC_PORT=9082
PAYMENT_GRPC_PORT=9083
SAGA_GRPC_PORT=9084

# ---------- JWT ----------
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_TOKEN_EXPIRY=24h

# ---------- Tracing (planned) ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER_RATIO=1.0
